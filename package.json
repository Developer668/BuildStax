{
  "name": "buildstax",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "postcss": "8.5.19"
  },
  "scripts": {
    "dev": "tsx server.mts",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.mts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "backend:configure": "node scripts/configure-linked-backends.mjs",
    "backend:mcp:verify": "node scripts/verify-insforge-mcp.mjs",
    "backend:runtime:verify": "node scripts/verify-insforge-runtime.mjs",
    "nexla:mcp:verify": "node --env-file=.env --env-file=.env.local scripts/verify-nexla-mcp.mjs",
    "auth:hash": "node scripts/hash-password.mjs",
    "pomerium:up": "docker compose --env-file .env.local -f compose.pomerium.yaml up -d",
    "pomerium:down": "docker compose --env-file .env.local -f compose.pomerium.yaml down"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@insforge/sdk": "^1.4.5",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "next": "16.2.10",
    "plivo": "4.75.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.23.1",
    "ws": "^8.21.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@insforge/mcp": "^1.2.11",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true,
    "esbuild@0.28.1": true
  }
}
