# Application
APP_MODE=sandbox
DATA_BACKEND=insforge
APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_INSFORGE_URL=https://your-linked-project.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=replace_with_insforge_anon_key
INSFORGE_API_KEY=replace_with_server_only_project_api_key
AUTH_RATE_LIMIT_SECRET=replace_with_at_least_32_random_characters

# Explicit offline fallback. Set DATA_BACKEND=sqlite to use it.
DATABASE_URL=file:./data/buildstax.db
AUTH_SECRET=replace_with_at_least_32_random_characters
ADMIN_EMAIL=operator@buildstax.local
ADMIN_NAME=BuildStax Owner
ADMIN_PASSWORD_HASH=scrypt$replace_with_generated_hash
# ADMIN_PASSWORD is supported for local development only. Prefer ADMIN_PASSWORD_HASH.
# SEED_SANDBOX_DATA=true

# Zero capability router. Paid calls remain disabled unless explicitly enabled.
ZERO_RUNNER=/usr/local/bin/zero
# Inject a short-lived session at runtime only; never pass it as a build argument.
ZERO_SESSION_TOKEN=replace_with_runtime_only_short_lived_session_token
ZERO_LIVE_ACTIONS=false

# Nexla persistent data and agent memory
NEXLA_API_URL=replace_with_verified_nexla_api_url
NEXLA_SERVICE_KEY=replace_with_server_side_service_key
NEXLA_TOKEN=replace_with_short_lived_session_token
NEXLA_INGEST_URL=https://replace_with_nexla_webhook_url
NEXLA_SOURCE_ID=replace_with_source_id
NEXLA_NEXSET_ID=replace_with_nexset_id
NEXLA_TOOLSET_ID=replace_with_toolset_id
NEXLA_MONITORING_URL=https://veda-ai.nexla.io/monitoring/

# OpenAI Realtime voice model
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_REALTIME_VOICE=marin

# Plivo programmable voice transport. Keep all credentials server-only.
PLIVO_AUTH_ID=replace_with_plivo_auth_id
PLIVO_AUTH_TOKEN=replace_with_plivo_auth_token
PLIVO_APPLICATION_ID=replace_with_plivo_application_id
PLIVO_TEST_NUMBER=+15555550100
PLIVO_PRIMARY_NUMBER=+15555550101
PLIVO_TEST_DESTINATION=+15555550102
PLIVO_PUBLIC_BASE_URL=https://buildstax.example.com
PLIVO_STREAM_SECRET=replace_with_at_least_32_random_characters
PLIVO_LIVE_CALLS_ENABLED=false
PLIVO_MAX_CALL_SECONDS=900
PLIVO_INBOUND_WORKSPACE_ID=replace_with_workspace_uuid
PLIVO_INBOUND_CAMPAIGN_ID=replace_with_campaign_id
# Optional OpenAI-compatible/custom realtime WebSocket provider overrides.
# VOICE_AGENT_WS_URL=wss://api.openai.com/v1/realtime?model=gpt-realtime
# VOICE_AGENT_API_KEY=replace_with_server_only_realtime_key
# VOICE_AGENT_MODEL=gpt-realtime
# VOICE_AGENT_VOICE_ID=voice_replace_with_custom_voice_id

# Optional AkashML model provider
AKASHML_API_KEY=replace_with_akashml_api_key
AKASHML_MODEL=replace_with_verified_model_id
AKASHML_PITCH_RESERVATION_CENTS=25

# Stripe Checkout. Never expose the secret key to the browser.
STRIPE_ENVIRONMENT=test
STRIPE_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_PRODUCT_ID=prod_replace_me
STRIPE_WEBHOOK_ENDPOINT_ID=we_replace_me

# Pomerium deployment access layer
POMERIUM_CLUSTER_TOKEN=replace_with_pomerium_cluster_token
POMERIUM_HEALTH_URL=http://127.0.0.1:28080/readyz
POMERIUM_ZERO_API_URL=https://console.pomerium.app/api/v0
POMERIUM_ZERO_API_TOKEN=replace_with_pomerium_api_user_token
POMERIUM_ZERO_ORGANIZATION_ID=replace_with_pomerium_organization_id
POMERIUM_ZERO_NAMESPACE_ID=replace_with_pomerium_cluster_namespace_id
POMERIUM_ZERO_POLICY_ID=replace_with_buildstax_policy_id
POMERIUM_ZERO_ROUTE_ID=replace_with_buildstax_route_id
POMERIUM_ZERO_ROUTE_URL=https://buildstax.example-cluster.pomerium.app
POMERIUM_UPSTREAM_URL=http://host.docker.internal:3000
